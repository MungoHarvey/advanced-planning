# Advanced Planning System — .gitignore

# ── Platform-internal directories ─────────────────────────────────────────────
.claude/

# ── Snapshot checkpoints (potentially large; restore from git instead) ─────────
state/snapshots/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
.env

# ── Secrets and credentials ───────────────────────────────────────────────────
*.pem
*.key
.env.local
.env.*.local
secrets.json
credentials.json
*_credentials.json
*_secret*

# ── OS files ───────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor files ───────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.cursor/

# ── Node (for any tooling scripts) ────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── CI cache ──────────────────────────────────────────────────────────────────
.cache/

# ── Pytest session artefacts ──────────────────────────────────────────────────
pytest-cache-files-*
